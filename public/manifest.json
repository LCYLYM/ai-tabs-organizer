{
  "manifest_version": 3,
  "name": "AI 标签页自动分类",
  "description": "使用 OpenAI 兼容接口或 Chrome 内置 AI 自动为标签页分组与打标。",
  "version": "0.1.0",
  "minimum_chrome_version": "138",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "options_page": "options/index.html",
  "action": {
    "default_title": "AI 标签页自动分类",
    "default_popup": "popup/index.html"
  }
}
